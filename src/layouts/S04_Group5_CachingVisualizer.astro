---
/**
 * S04_Group5_CachingVisualizer.astro
 *
 * A fully custom layout for the Caching Visualizer exhibit.
 * Completely unique design — does NOT reuse ExhibitLayout.
 *
 * Features:
 *  - Immersive full-bleed hero with animated gradient mesh
 *  - Horizontal sticky navigation auto-generated from headings
 *  - Clean dark reading surface with strong typographic hierarchy
 *  - Circuit-inspired decorative accents
 *  - Fully responsive (mobile → desktop)
 */

const { title, author, readingTime } = Astro.props.frontmatter ?? Astro.props;
const { headings } = Astro.props;

import 'normalize.css';
import '@fontsource-variable/lora';
import '@fontsource-variable/noto-sans';
import '@fontsource/jetbrains-mono';

import { Icon } from 'astro-icon/components';

const baseUrl = import.meta.env.BASE_URL;

const navItems = headings?.filter((h: { depth: number }) => h.depth >= 2 && h.depth <= 3) ?? [];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — CSARCH2 Virtual Exhibit</title>
    <meta name="description" content="An interactive virtual exhibit on CPU Cache Memory Mechanisms" />
  </head>

  <body class="cv-root">
    <!-- ─── HERO ──────────────────────────────────────────────── -->
    <header class="cv-hero">
      <div class="cv-hero__mesh" aria-hidden="true"></div>
      <div class="cv-hero__grid" aria-hidden="true"></div>
      <div class="cv-hero__glow cv-hero__glow--cyan" aria-hidden="true"></div>
      <div class="cv-hero__glow cv-hero__glow--indigo" aria-hidden="true"></div>

      <div class="cv-hero__content">
        <a href={baseUrl} class="cv-hero__back">
          <Icon name="ic:round-home" width="18" height="18" />
          <span>Exhibit Hub</span>
        </a>

        <p class="cv-hero__eyebrow">
          <span class="cv-hero__eyebrow-dot"></span>
          CSARCH2 — Virtual Exhibit
        </p>

        <h1 class="cv-hero__title">
          <span class="cv-hero__title-main" set:html={title} />
        </h1>

        <div class="cv-hero__meta">
          <span class="cv-hero__meta-item">
            <Icon name="ic:round-person" width="16" height="16" />
            {author}
          </span>
          {readingTime && (
            <span class="cv-hero__meta-item">
              <Icon name="ic:round-schedule" width="16" height="16" />
              {readingTime}
            </span>
          )}
        </div>

        <div class="cv-hero__signal" aria-hidden="true">
          <span class="cv-hero__signal-bar"></span>
          <span class="cv-hero__signal-bar"></span>
          <span class="cv-hero__signal-bar"></span>
          <span class="cv-hero__signal-bar"></span>
          <span class="cv-hero__signal-bar"></span>
        </div>
      </div>
    </header>

    <!-- ─── STICKY NAV ────────────────────────────────────────── -->
    {navItems.length > 0 && (
      <nav class="cv-nav" id="cv-nav" aria-label="Page sections">
        <div class="cv-nav__rail">
          {navItems.map((h: { slug: string; text: string; depth: number }) => (
            <a
              href={`#${h.slug}`}
              class:list={['cv-nav__link', { 'cv-nav__link--sub': h.depth === 3 }]}
            >
              {h.text}
            </a>
          ))}
        </div>
      </nav>
    )}

    <!-- ─── MAIN CONTENT ──────────────────────────────────────── -->
    <main class="cv-main">
      <article class="cv-article">
        <slot />
      </article>
    </main>

    <!-- ─── FOOTER ────────────────────────────────────────────── -->
    <footer class="cv-footer">
      <div class="cv-footer__rule" aria-hidden="true"></div>
      <div class="cv-footer__inner">
        <div class="cv-footer__brand">
          <span class="cv-footer__logo">Ca-Ching!</span>
          <span class="cv-footer__sep">·</span>
          <span>CSARCH2 Virtual Exhibit</span>
        </div>
        <p class="cv-footer__tagline">Computer Architecture is Forever</p>
      </div>
    </footer>
  </body>
</html>

<!-- ─── STYLES ────────────────────────────────────────────────── -->
<style>
  /* ================================================================
     DESIGN TOKENS
     ================================================================ */
  :root {
    --cv-bg-deep:    #06080f;
    --cv-bg-surface: #0c1021;
    --cv-bg-card:    #111630;
    --cv-border:     rgba(99, 102, 241, 0.18);
    --cv-text:       #e2e8f0;
    --cv-text-dim:   #94a3b8;
    --cv-text-faint: #475569;
    --cv-accent-cyan:    #22d3ee;
    --cv-accent-indigo:  #818cf8;
    --cv-accent-emerald: #34d399;
    --cv-accent-amber:   #fbbf24;
    --cv-glow-cyan:   rgba(34, 211, 238, 0.15);
    --cv-glow-indigo: rgba(129, 140, 248, 0.15);
    --cv-radius: 0.75rem;
    --cv-font-body: 'Noto Sans Variable', system-ui, sans-serif;
    --cv-font-heading: 'Lora Variable', Georgia, serif;
    --cv-font-mono: 'JetBrains Mono', Consolas, monospace;
  }

  /* ================================================================
     RESET / BASE
     ================================================================ */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .cv-root {
    font-family: var(--cv-font-body);
    color: var(--cv-text);
    background: var(--cv-bg-deep);
    line-height: 1.65;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ================================================================
     HERO
     ================================================================ */
  .cv-hero {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    min-height: clamp(400px, 70vh, 700px);
    padding: 3rem 4rem 4rem;
    background: var(--cv-bg-deep);
  }

  /* Animated gradient mesh background */
  .cv-hero__mesh {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 15% 50%, rgba(34,211,238,0.12) 0%, transparent 70%),
      radial-gradient(ellipse 60% 80% at 85% 30%, rgba(129,140,248,0.10) 0%, transparent 70%),
      radial-gradient(ellipse 50% 50% at 50% 90%, rgba(52,211,153,0.08) 0%, transparent 60%);
    animation: cv-mesh-drift 12s ease-in-out infinite alternate;
  }

  @keyframes cv-mesh-drift {
    0%   { opacity: 0.8; transform: scale(1) translate(0, 0); }
    50%  { opacity: 1;   transform: scale(1.05) translate(-2%, 1%); }
    100% { opacity: 0.9; transform: scale(1) translate(1%, -1%); }
  }

  /* Subtle grid overlay */
  .cv-hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(99,102,241,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(99,102,241,0.05) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse 70% 70% at 50% 60%, black 20%, transparent 80%);
  }

  /* Glow orbs */
  .cv-hero__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
  }
  .cv-hero__glow--cyan {
    width: 700px; height: 700px;
    top: -15%; left: 5%;
    background: var(--cv-glow-cyan);
    animation: cv-glow-pulse 8s ease-in-out infinite;
  }
  .cv-hero__glow--indigo {
    width: 600px; height: 600px;
    bottom: -20%; right: 0%;
    background: var(--cv-glow-indigo);
    animation: cv-glow-pulse 10s ease-in-out infinite reverse;
  }

  @keyframes cv-glow-pulse {
    0%, 100% { opacity: 0.6; transform: translate(0, 0) scale(1); }
    50%      { opacity: 1;   transform: translate(2%, -3%) scale(1.1); }
  }

  .cv-hero__content {
    position: relative;
    z-index: 1;
    max-width: 80rem;
    width: 100%;
    margin: 0 auto;
  }

  /* Back link */
  .cv-hero__back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--cv-font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cv-text-dim);
    text-decoration: none;
    padding: 0.35rem 0.75rem;
    border: 1px solid rgba(148,163,184,0.2);
    border-radius: 9999px;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
    margin-bottom: 1.5rem;
  }
  .cv-hero__back:hover {
    color: var(--cv-accent-cyan);
    border-color: rgba(34,211,238,0.4);
    background: rgba(34,211,238,0.06);
  }

  /* Eyebrow */
  .cv-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--cv-font-mono);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cv-accent-cyan);
    margin-bottom: 1.25rem;
  }

  .cv-hero__eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--cv-accent-cyan);
    box-shadow: 0 0 10px var(--cv-accent-cyan);
    animation: cv-dot-blink 2.5s ease-in-out infinite;
  }

  @keyframes cv-dot-blink {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.4; transform: scale(0.7); }
  }

  /* Title */
  .cv-hero__title {
    font-family: var(--cv-font-heading);
    font-size: clamp(2.2rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #f8fafc;
    margin-bottom: 2rem;
  }

  .cv-hero__title-main {
    background: linear-gradient(135deg, #f8fafc 30%, var(--cv-accent-cyan) 65%, var(--cv-accent-indigo) 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: cv-title-shimmer 8s ease infinite;
  }

  @keyframes cv-title-shimmer {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* Meta */
  .cv-hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .cv-hero__meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.82rem;
    color: var(--cv-text-dim);
    padding: 0.3rem 0.7rem;
    border: 1px solid rgba(148,163,184,0.15);
    border-radius: 9999px;
    background: rgba(255,255,255,0.03);
  }

  /* Signal bars decoration */
  .cv-hero__signal {
    display: flex;
    align-items: flex-end;
    gap: 5px;
    height: 28px;
  }

  .cv-hero__signal-bar {
    display: block;
    width: 4px;
    border-radius: 2px;
    background: var(--cv-accent-cyan);
    opacity: 0.6;
    animation: cv-signal-bounce 1.4s ease-in-out infinite;
  }
  .cv-hero__signal-bar:nth-child(1) { height: 30%; animation-delay: 0s; }
  .cv-hero__signal-bar:nth-child(2) { height: 60%; animation-delay: 0.15s; }
  .cv-hero__signal-bar:nth-child(3) { height: 100%; animation-delay: 0.3s; }
  .cv-hero__signal-bar:nth-child(4) { height: 60%; animation-delay: 0.45s; }
  .cv-hero__signal-bar:nth-child(5) { height: 30%; animation-delay: 0.6s; }

  @keyframes cv-signal-bounce {
    0%, 100% { transform: scaleY(1); opacity: 0.5; }
    50%      { transform: scaleY(1.4); opacity: 1; }
  }

  /* ================================================================
     STICKY NAV
     ================================================================ */
  .cv-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(6, 8, 15, 0.85);
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    border-bottom: 1px solid var(--cv-border);
  }

  .cv-nav__rail {
    display: flex;
    gap: 0.5rem;
    max-width: 100%;
    margin: 0 auto;
    padding: 0.75rem 4rem;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .cv-nav__rail::-webkit-scrollbar { display: none; }

  .cv-nav__link {
    flex-shrink: 0;
    font-family: var(--cv-font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--cv-text-dim);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    border: 1px solid transparent;
    transition: color 0.2s, background 0.2s, border-color 0.2s;
    white-space: nowrap;
  }

  .cv-nav__link:hover {
    color: var(--cv-accent-cyan);
    background: rgba(34,211,238,0.06);
    border-color: rgba(34,211,238,0.2);
  }

  .cv-nav__link--sub {
    font-size: 0.65rem;
    opacity: 0.75;
  }
  .cv-nav__link--sub:hover { opacity: 1; }

  /* ================================================================
     MAIN CONTENT
     ================================================================ */
  .cv-main {
    flex: 1;
    width: 100%;
    padding: 3rem 4rem 5rem;
  }

  .cv-article {
    background: var(--cv-bg-surface);
    border: 1px solid var(--cv-border);
    border-radius: calc(var(--cv-radius) * 1.5);
    padding: 4rem 5rem;
    box-shadow:
      0 0 120px rgba(34,211,238,0.04),
      0 0 60px rgba(99,102,241,0.04),
      0 32px 64px rgba(0,0,0,0.4);
  }

  /* ── Typography overrides inside article ── */
  .cv-article :global(h1) {
    display: none; /* Title is in hero; hide the MDX h1 */
  }

  .cv-article :global(h2) {
    font-family: var(--cv-font-heading);
    font-size: 1.85rem;
    font-weight: 700;
    color: #f1f5f9;
    margin: 4rem 0 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(99,102,241,0.15);
    line-height: 1.3;
  }
  .cv-article :global(h2:first-of-type) {
    margin-top: 0;
  }

  .cv-article :global(h3) {
    font-family: var(--cv-font-heading);
    font-size: 1.4rem;
    font-weight: 600;
    color: #e2e8f0;
    margin: 3rem 0 1.25rem;
    line-height: 1.35;
  }

  .cv-article :global(h4),
  .cv-article :global(h5),
  .cv-article :global(h6) {
    font-family: var(--cv-font-heading);
    font-weight: 600;
    color: #e2e8f0;
    margin: 2rem 0 0.75rem;
  }

  .cv-article :global(p) {
    color: var(--cv-text);
    margin: 1rem 0;
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .cv-article :global(a) {
    color: var(--cv-accent-cyan);
    text-decoration-color: rgba(34,211,238,0.35);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s;
  }
  .cv-article :global(a:hover) {
    text-decoration-color: var(--cv-accent-cyan);
  }

  .cv-article :global(ul),
  .cv-article :global(ol) {
    padding-left: 1.5rem;
    margin: 0.75rem 0;
    color: var(--cv-text);
  }
  .cv-article :global(ul) { list-style: disc; }
  .cv-article :global(ol) { list-style: decimal; }
  .cv-article :global(li) { margin: 0.35rem 0; }

  .cv-article :global(strong) {
    color: #f1f5f9;
    font-weight: 700;
  }

  .cv-article :global(code) {
    font-family: var(--cv-font-mono);
    font-size: 0.875em;
    background: rgba(34,211,238,0.08);
    color: var(--cv-accent-cyan);
    padding: 0.15em 0.45em;
    border-radius: 4px;
    border: 1px solid rgba(34,211,238,0.15);
  }

  .cv-article :global(pre) {
    background: var(--cv-bg-deep) !important;
    border: 1px solid var(--cv-border);
    border-radius: var(--cv-radius);
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .cv-article :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: inherit;
  }

  .cv-article :global(blockquote) {
    border-left: 3px solid var(--cv-accent-indigo);
    background: rgba(129,140,248,0.06);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    border-radius: 0 var(--cv-radius) var(--cv-radius) 0;
    color: var(--cv-text-dim);
  }

  .cv-article :global(hr) {
    border: none;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(99,102,241,0.25) 25%,
      rgba(34,211,238,0.25) 75%,
      transparent
    );
    margin: 3rem 0;
  }

  .cv-article :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }

  .cv-article :global(th),
  .cv-article :global(td) {
    padding: 0.7rem 1rem;
    border: 1px solid var(--cv-border);
    text-align: left;
  }

  .cv-article :global(th) {
    background: rgba(99,102,241,0.08);
    font-weight: 600;
    color: #e2e8f0;
    font-family: var(--cv-font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
  }

  .cv-article :global(td) {
    color: var(--cv-text);
  }

  /* ================================================================
     FOOTER
     ================================================================ */
  .cv-footer {
    padding: 0 4rem 3rem;
  }

  .cv-footer__rule {
    max-width: 100%;
    margin: 0 auto 2.5rem;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(99,102,241,0.3) 20%,
      rgba(34,211,238,0.3) 50%,
      rgba(99,102,241,0.3) 80%,
      transparent
    );
  }

  .cv-footer__inner {
    max-width: 100%;
    margin: 0 auto;
    text-align: center;
  }

  .cv-footer__brand {
    font-family: var(--cv-font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: var(--cv-text-dim);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .cv-footer__logo {
    font-family: var(--cv-font-heading);
    font-weight: 800;
    font-size: 1.05rem;
    background: linear-gradient(135deg, var(--cv-accent-cyan), var(--cv-accent-indigo));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cv-footer__sep {
    opacity: 0.3;
  }

  .cv-footer__tagline {
    margin-top: 0.5rem;
    font-size: 0.72rem;
    color: var(--cv-text-faint);
    font-style: italic;
  }

  /* ================================================================
     RESPONSIVE — TABLET
     ================================================================ */
  @media (max-width: 1024px) {
    .cv-hero {
      padding: 2.5rem 2rem 3rem;
    }

    .cv-main {
      padding: 2rem 2rem 4rem;
    }

    .cv-article {
      padding: 2.5rem 2.5rem;
    }

    .cv-nav__rail {
      padding: 0.6rem 2rem;
    }

    .cv-footer {
      padding: 0 2rem 2.5rem;
    }
  }

  /* ================================================================
     RESPONSIVE — MOBILE
     ================================================================ */
  @media (max-width: 768px) {
    .cv-hero {
      min-height: clamp(300px, 50vh, 450px);
      padding: 2rem 1.25rem 2.5rem;
    }

    .cv-hero__title {
      font-size: clamp(1.6rem, 7vw, 2.2rem);
    }

    .cv-hero__meta {
      flex-direction: column;
      gap: 0.5rem;
    }

    .cv-nav__rail {
      padding: 0.5rem 1.25rem;
      gap: 0.3rem;
    }

    .cv-nav__link {
      font-size: 0.65rem;
      padding: 0.35rem 0.7rem;
    }

    .cv-main {
      padding: 1.5rem 1rem 3rem;
    }

    .cv-article {
      padding: 1.75rem 1.5rem;
      border-radius: 0.75rem;
    }

    .cv-article :global(h2) {
      font-size: 1.4rem;
      margin: 3rem 0 1.25rem;
    }

    .cv-article :global(h3) {
      font-size: 1.15rem;
    }

    .cv-article :global(p) {
      font-size: 1rem;
    }

    .cv-article :global(table) {
      display: block;
      overflow-x: auto;
    }

    .cv-footer {
      padding: 0 1.25rem 2rem;
    }
  }

  @media (max-width: 480px) {
    .cv-hero {
      min-height: 280px;
      padding: 1.5rem 1rem 2rem;
    }

    .cv-hero__title {
      font-size: 1.5rem;
    }

    .cv-main {
      padding: 1rem 0.75rem 2.5rem;
    }

    .cv-article {
      padding: 1.25rem 1rem;
      border-radius: 0.5rem;
    }

    .cv-nav__rail {
      padding: 0.4rem 0.75rem;
    }

    .cv-footer {
      padding: 0 1rem 1.5rem;
    }

    .cv-footer__brand {
      font-size: 0.68rem;
    }
  }
</style>
